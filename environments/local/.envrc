# Local Development Environment Configuration
# This file is sourced both by direnv (from its own directory)
# and by run.sh (from the repo root) — so all paths use ENV_DIR, not pwd.
ENV_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
REPO_ROOT="$(cd "${ENV_DIR}/../.." && pwd)"

export SHARED_DIR_PATH="${REPO_ROOT}/shared"
export PLAYBOOK_DIR="${SHARED_DIR_PATH}/ansible/playbooks"
export PD="${PLAYBOOK_DIR}"

# Ansible
export ANSIBLE_CONFIG="${SHARED_DIR_PATH}/configs/ansible.cfg"
export ANSIBLE_INVENTORY="${ENV_DIR}/ansible"
export ANSIBLE_INVENTORY_ENV=local
export ANSIBLE_ENVIRONMENT=local

# SOPS age key location
export SOPS_AGE_KEY_FILE="${HOME}/.config/sops/age/keys.txt"

# Kubeconfig location for local cluster
export KUBECONFIG="${ENV_DIR}/kubeconfig"

# Terraform variables
export TF_VAR_environment="local"
# Read proxmox IP from ansible host_vars (single source of truth)
TF_VAR_proxmox_host=$(grep '^ansible_host:' "${ENV_DIR}/ansible/host_vars/pve02/00-general.yaml" | awk '{print $2}' | tr -d '"')
export TF_VAR_proxmox_host

# Step runner
export SCRIPT_DIR="${ENV_DIR}"
export OUTPUTS_DIR="${ENV_DIR}/outputs"
export SOCKS_PORT="${SOCKS_PORT:-5801}"

# Vault password file (if using ansible-vault instead of sops)
# export ANSIBLE_VAULT_PASSWORD_FILE="${HOME}/.ansible/vault_pass_local.txt"

echo "Local development environment configured"
echo "Proxmox: https://${TF_VAR_proxmox_host}:8006"
echo "Environment: ${ANSIBLE_ENVIRONMENT}"
