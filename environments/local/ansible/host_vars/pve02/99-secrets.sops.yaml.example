# Example secrets file for local environment
# Copy this to 99-secrets.sops.yaml and encrypt with SOPS
#
# To create encrypted version (from this directory):
#   cp 99-secrets.sops.yaml.example 99-secrets.sops.yaml
#   # Edit 99-secrets.sops.yaml and set real passwords, then:
#   sops --config ../../../../shared/configs/sops.yaml --encrypt -i 99-secrets.sops.yaml
#
# To edit the encrypted file:
#   sops 99-secrets.sops.yaml
#   # or with explicit config:
#   SOPS_CONFIG_PATH=../../../../shared/configs/sops.yaml sops 99-secrets.sops.yaml

---
# Proxmox API User (for Terraform and Ansible)
proxmox_user: "automation"
proxmox_password: "CHANGE_ME_STRONG_PASSWORD"
proxmox_role_name: "AutomationRole"

# Proxmox root password
# Default Vagrant password is 'vagrant' - change this immediately!
root_password: "CHANGE_ME_ROOT_PASSWORD"

# Optional: SSH key for automation
# automation_ssh_key: "ssh-rsa AAAAB3NzaC1yc2E..."

# FluxCD Git deploy key (SSH private key for fleet repo access)
# Generate: ssh-keygen -t ed25519 -f flux-deploy-key -C "flux-local"
# Add the public key as a deploy key on the Git repo (with write access)
flux_git_deploy_key: |
  -----BEGIN OPENSSH PRIVATE KEY-----
  CHANGE_ME
  -----END OPENSSH PRIVATE KEY-----
